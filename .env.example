# --- General ---
# Environment mode (development, production)
NODE_ENV=development

# --- Database ---
# PostgreSQL credentials for Docker Compose
POSTGRES_USER=ai-gatekeeper
POSTGRES_PASSWORD=ai-gatekeeper
POSTGRES_DB=ai-gatekeeper

# PostgreSQL connection string
DATABASE_URL=postgres://ai-gatekeeper:ai-gatekeeper@127.0.0.1:5433/ai-gatekeeper

# --- Redis ---
# Redis connection string
REDIS_URL=redis://127.0.0.1:6379

# --- Web App ---
# JWT signing secret — required for auth
JWT_SECRET=dev-jwt-secret-do-not-use-in-production
# Public URL of the web application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Proxy ---
# Port for the proxy server
PROXY_PORT=3001
# Base URL for the proxy used by the web app integrations
PROXY_BASE_URL=http://localhost:3001/v1

# --- Global Provider API Keys (Fallbacks) ---
# If a project does not have these configured, the proxy falls back to these global keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
