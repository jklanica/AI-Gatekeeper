{
  "name": "@ai-gatekeeper/root",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "pnpm --filter @ai-gatekeeper/db run db:push",
    "db:studio": "pnpm --filter @ai-gatekeeper/db run db:studio"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.9.16",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
